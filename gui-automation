#!/usr/bin/env python3
import subprocess
import sys
import os
import time
import cv2
import numpy as np
from PIL import Image

SCREENSHOT_DIR = "/tmp/automation"
os.makedirs(SCREENSHOT_DIR, exist_ok=True)

_vi = None
_screen_size = (1920, 1080)
_ydotool_socket = "/tmp/.ydotool_socket"

def ensure_ydotoold():
    global _ydotool_socket
    import subprocess
    import os
    if not os.path.exists(_ydotool_socket):
        try:
            subprocess.Popen(['ydotoold', '--socket-path', _ydotool_socket], 
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            import time; time.sleep(0.5)
        except:
            pass
    return os.path.exists(_ydotool_socket)

def get_screen_size():
    global _screen_size
    try:
        result = subprocess.run(['xdotool', 'getdisplaygeometry'], capture_output=True, text=True, timeout=2)
        if result.returncode == 0:
            w, h = result.stdout.strip().split()
            _screen_size = (int(w), int(h))
    except:
        pass
    return _screen_size

def get_virtual_input():
    global _vi
    if _vi is None:
        try:
            sys.path.insert(0, '/home/zius/bin')
            from virtual_input import VirtualInput
            w, h = get_screen_size()
            _vi = VirtualInput()
            _vi.create_mouse(width=w, height=h)
            _vi.create_keyboard()
        except Exception as e:
            print(f"Failed to init virtual input: {e}")
            _vi = False
    return _vi if _vi else None

def run_ydotool(args):
    env = os.environ.copy()
    env['YDOTOOL_SOCKET'] = _ydotool_socket
    ensure_ydotoold()
    result = subprocess.run(['ydotool'] + args, env=env, capture_output=True, timeout=5)
    return result.returncode == 0

def run_ydotool(args):
    env = os.environ.copy()
    env['YDOTOOL_SOCKET'] = '/tmp/.ydotool_socket'
    result = subprocess.run(['ydotool'] + args, env=env, capture_output=True)
    return result.returncode == 0

def run_xdotool(args):
    result = subprocess.run(['xdotool'] + args, capture_output=True)
    return result.returncode == 0

def screenshot(path=None):
    if path is None:
        path = f"{SCREENSHOT_DIR}/screen.png"
    # Use grim for Wayland, fallback to scrot for X11
    if os.environ.get('WAYLAND_DISPLAY'):
        try:
            subprocess.run(['grim', path], check=True)
        except:
            subprocess.run(['scrot', path], check=True)
    else:
        subprocess.run(['scrot', path], check=True)
    return path

def find_image(template_path, threshold=0.8):
    screenshot()
    screen = cv2.imread(f"{SCREENSHOT_DIR}/screen.png")
    template = cv2.imread(template_path)
    
    if screen is None:
        print("Error: Could not read screenshot")
        return None
    if template is None:
        print(f"Error: Could not read template: {template_path}")
        return None
    
    result = cv2.matchTemplate(screen, template, cv2.TM_CCOEFF_NORMED)
    _, max_val, _, max_loc = cv2.minMaxLoc(result)
    
    if max_val >= threshold:
        x, y = max_loc
        w, h = template.shape[1], template.shape[0]
        return (x + w//2, y + h//2, max_val)
    return None

_mouse_x, _mouse_y = 0, 0

def mouse_move(x, y):
    global _mouse_x, _mouse_y
    if run_ydotool(['mousemove', str(x), str(y)]):
        _mouse_x, _mouse_y = x, y
        return
    vi = get_virtual_input()
    if vi:
        vi.move_mouse_abs(x, y)
        _mouse_x, _mouse_y = x, y

def click(x=None, y=None, button=0):
    if x is not None and y is not None:
        mouse_move(x, y)
        time.sleep(0.1)
    if run_ydotool(['click', '0']):
        return
    vi = get_virtual_input()
    if vi:
        vi.click('left')

def type_text(text):
    if run_ydotool(['type', '--', text]):
        return
    vi = get_virtual_input()
    if vi:
        vi.type_text(text)

def press_key(key):
    if run_ydotool(['key', key]):
        return
    vi = get_virtual_input()
    if vi:
        vi.press_key(key)

if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "help"
    
    if cmd == "screenshot":
        print(screenshot())
    elif cmd == "click" and len(sys.argv) >= 4:
        click(int(sys.argv[2]), int(sys.argv[3]))
    elif cmd == "move" and len(sys.argv) >= 4:
        mouse_move(int(sys.argv[2]), int(sys.argv[3]))
    elif cmd == "type" and len(sys.argv) >= 3:
        type_text(sys.argv[2])
    elif cmd == "press" and len(sys.argv) >= 3:
        press_key(sys.argv[2])
    elif cmd == "find" and len(sys.argv) >= 3:
        result = find_image(sys.argv[2])
        if result:
            print(f"Found at: {result[0]}, {result[1]} (confidence: {result[2]:.2f})")
        else:
            print("Not found")
    elif cmd == "size":
        screenshot()
        img = cv2.imread(f"{SCREENSHOT_DIR}/screen.png")
        print(f"{img.shape[1]}x{img.shape[0]}")
    else:
        print("Usage: gui screenshot|click X Y|move X Y|type TEXT|press KEY|find IMAGE|size")
